{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ardasevinc/tele/schemas/v1alpha1/record.schema.json",
  "title": "tele v1alpha1 JSONL record",
  "type": "object",
  "required": ["schema_version", "type"],
  "properties": {
    "schema_version": { "const": "tele/v1alpha1" },
    "type": { "enum": ["meta", "data", "error"] },
    "meta": { "$ref": "envelope.schema.json#/$defs/meta" },
    "data": true,
    "error": { "$ref": "error.schema.json#/$defs/error" }
  },
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": { "type": { "const": "meta" } },
      "required": ["meta"],
      "not": { "anyOf": [{ "required": ["data"] }, { "required": ["error"] }] }
    },
    {
      "properties": { "type": { "const": "data" } },
      "required": ["data"],
      "not": { "anyOf": [{ "required": ["meta"] }, { "required": ["error"] }] }
    },
    {
      "properties": { "type": { "const": "error" } },
      "required": ["meta", "error"],
      "not": { "required": ["data"] }
    }
  ]
}
